{
  "manifest_version": 3,
  "name": "WARDEN — Adware & Spyware Blocker",
  "version": "2.0.0",
  "description": "Blocks known ad/tracker requests at the network level, removes ad/spyware DOM injections safely, and flags third-party scripts that monitor keystrokes.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "webRequest",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ads_trackers",
        "enabled": true,
        "path": "rules/ads-trackers.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page-hook.js"],
      "all_frames": true,
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WARDEN",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
